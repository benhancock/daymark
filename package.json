{
  "name": "daymark",
  "version": "0.1.1",
  "description": "Reveals when later additions were made without changing note Markdown.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "author": "benhancock",
